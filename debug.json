      "reviewSummary": {
        "text": {
          "text": "People say this cafe offers delicious Hue salted coffee, matcha, and pistachio lattes. They highlight the cozy, welcoming vibe and the friendly, attentive staff. They also like the clean and comfortable atmosphere, perfect for studying, working, or hanging out with friends.",
          "languageCode": "en-US"
        },
        "flagContentUri": "https://www.google.com/local/review/rap/report?postId=5%401:CAIQACodChtyc19oOkc5aU1aa0xkV2lpNEVqSEpKRmFBZ0E%7CCAIQACorChtyc19oOkc5aU1aa0xkV2lpNEVqSEpKRmFBZ0ESDAiu2KnHBhCQ5ojFAw&d=17924085&t=8",
