      "reviews": [
        {
          "name": "places/ChIJa7zfoiDLRIYR1Sb-iOrB62E/reviews/Ci9DQUlRQUNvZENodHljRjlvT2paNVlsRXRVSEZsY0V4ZmVtaHdibTVsTlhrMlNYYxAB",
          "relativePublishTimeDescription": "a month ago",
          "rating": 5,
          "text": {
            "text": "Love how warm and welcoming the atmosphere of this new business is. Very cozy place to come in and study, though noise levels can get a bit high during peak service times. The coffee is a lot stronger than I’m used to, which was a surprise, but once I knew what to expect I thought it tasted great! The owners and people behind the counter have all been extremely friendly as well, and I’ve consistently felt very welcomed in the space. I’ll definitely be a repeat customer here! :)",
            "languageCode": "en"
          },
          "originalText": {
            "text": "Love how warm and welcoming the atmosphere of this new business is. Very cozy place to come in and study, though noise levels can get a bit high during peak service times. The coffee is a lot stronger than I’m used to, which was a surprise, but once I knew what to expect I thought it tasted great! The owners and people behind the counter have all been extremely friendly as well, and I’ve consistently felt very welcomed in the space. I’ll definitely be a repeat customer here! :)",
            "languageCode": "en"
          },
