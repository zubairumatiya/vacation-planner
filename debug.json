  "contextualContents": [
    {
      "reviews": [
        {
          "name": "places/ChIJa7zfoiDLRIYR1Sb-iOrB62E/reviews/Ci9DQUlRQUNvZENodHljRjlvT2psUlZHVkdVV1YzU21oWFpqVlZVbVJXYTBsVVNsRRAB",
          "relativePublishTimeDescription": "2 months ago",
          "rating": 5,
          "text": {
            "text": "I had such a wonderful experience at this coffee shop! The staff here are incredibly polite and genuinely friendly. Even when they weren’t officially setup to open yet, they went out of their way to help our group make drinks, which I really appreciated. The coffee is excellent, rich and smooth, and their matcha is just as impressive, perfectly balanced and not too sweet. It’s rare to find a spot that combines great drinks with such thoughtful, welcoming service. Highly recommend!",
            "languageCode": "en"
          },
          "originalText": {
            "text": "I had such a wonderful experience at this coffee shop! The staff here are incredibly polite and genuinely friendly. Even when they weren’t officially setup to open yet, they went out of their way to help our group make drinks, which I really appreciated. The coffee is excellent, rich and smooth, and their matcha is just as impressive, perfectly balanced and not too sweet. It’s rare to find a spot that combines great drinks with such thoughtful, welcoming service. Highly recommend!",
            "languageCode": "en"
          },
          "authorAttribution": {
            "displayName": "Shashi Kranth",
            "uri": "https://www.google.com/maps/contrib/117323672495516463324/reviews",
            "photoUri": "https://lh3.googleusercontent.com/a-/ALV-UjWdHj2mvmvQ2ccXL-e65RYYcaDZgzK3ZpAor09_s1uJg1X74n8giw=s128-c-c0x00000000-cc-rp-mo-br100"
          },
