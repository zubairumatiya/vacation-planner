PORT=5000
NODE_ENV=development

# Database
DB_URL=postgresql://user:password@host:port/database

# JWT Secrets (generate with: openssl rand -base64 32)
SIGNATURE=your_access_token_secret
SIGNATURE2=your_refresh_token_secret

# URLs
FRONTEND_URL=https://localhost:5173
BACKEND_BASE_URL=https://localhost:5000
# PROD_URL=https://your-production-url.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
MY_DOMAIN_EMAIL=noreply@yourdomain.com
APP_NAME=Vacation-Planner

# Google Services
MAPS_API_KEY=your_google_maps_api_key
GEMINI_API_KEY=your_gemini_api_key
