{
  "compilerOptions": {
    "typeRoots": ["./types", "./node_modules/@types"],
    "module": "esnext",
    "moduleResolution": "node",
    "target": "esnext",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "esModuleInterop": true
  },
  "include": ["."],
  "exclude": ["dist", "node_modules"]
}
